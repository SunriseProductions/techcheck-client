# Build-time secrets for the sunrise-techcheck desktop client.
# Copy this file to `private/secrets.env` and fill in real values before
# running `make build-desktop`. The Makefile sources this file (if present)
# and passes the values via -ldflags into the binary.
#
# DO NOT commit secrets.env. It is gitignored.

# Bearer token for report uploads to the ingest service.
UPLOAD_TOKEN=

# Report upload endpoint URL.
INGEST_URL=

# IT support email shown to end users.
IT_CONTACT_EMAIL=

# JSON-encoded fallback POP list, used when the dynamic POP fetch fails.
# Example: [{"id":"eu-west-2","region_label":"London","hostname":"euw2.beacon.example.com","udp_echo":true}]
FALLBACK_POPS_JSON=

# -- macOS code signing & notarisation (optional) ----------------------------
# `make build-desktop` works without these — it falls back to ad-hoc signing,
# which produces binaries usable on the build machine but rejected by
# Gatekeeper elsewhere. `make release-desktop` requires all four.

# Full Developer ID Application identity string. Find with:
#   security find-identity -v -p codesigning
# Example: Developer ID Application: Sunrise Productions Ltd (ABCD1234EF)
APPLE_SIGN_IDENTITY=

# Apple ID email associated with the developer account.
APPLE_ID=

# 10-character Team ID from developer.apple.com → Membership.
APPLE_TEAM_ID=

# App-specific password from appleid.apple.com →
# "Sign-In and Security" → "App-Specific Passwords". Used by notarytool.
APPLE_APP_PASSWORD=
