# Build-time secrets for the sunrise-techcheck desktop client.
# Copy this file to `private/secrets.env` and fill in real values before
# running `make build-desktop`. The Makefile sources this file (if present)
# and passes the values via -ldflags into the binary.
#
# DO NOT commit secrets.env. It is gitignored.

# Bearer token for report uploads to the ingest service.
UPLOAD_TOKEN=

# Report upload endpoint URL.
INGEST_URL=

# IT support email shown to end users.
IT_CONTACT_EMAIL=

# JSON-encoded fallback POP list, used when the dynamic POP fetch fails.
# Example: [{"id":"eu-west-2","region_label":"London","hostname":"euw2.beacon.example.com","udp_echo":true}]
FALLBACK_POPS_JSON=
